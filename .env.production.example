# Copy this file to .env on the EC2 host next to docker-compose.prod.yml.

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/flux
JWT_SECRET=replace-with-a-long-random-secret

ADMIN_EMAILS=owner@example.com
FRONTEND_URL=http://YOUR_EC2_PUBLIC_IP
NEXT_PUBLIC_API_URL=http://YOUR_EC2_PUBLIC_IP/api

# Gmail SMTP example. Use a Google App Password, not your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_FAMILY=4
SMTP_USER=owner@example.com
SMTP_PASS=your-google-app-password
SMTP_FROM=Flux <owner@example.com>

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
